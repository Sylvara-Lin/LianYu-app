<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- All traffic uses HTTPS — no cleartext exceptions -->

    <!-- Debug overrides: allow system certificates for development -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
